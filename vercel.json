{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/health", "destination": "/api/index" },
    { "source": "/balance/:path*", "destination": "/api/index" },
    { "source": "/liquidity/:path*", "destination": "/api/index" },
    { "source": "/portfolio/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
